{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information and subscription details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string" },
        "subscriptionStatus": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "accessCode": { "type": "string" },
        "receiptImage": { "type": "string" },
        "paymentSubmittedAt": { "type": "string" },
        "approvedAt": { "type": "string" }
      },
      "required": ["id", "email", "password", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "amount": { "type": "number" },
        "bankName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "amount", "bankName", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of user accounts"
    },
    "transactions": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Collection of generated transactions"
    }
  }
}
